# Database
POSTGRES_USER=osu
POSTGRES_PASSWORD=osu
POSTGRES_DB=modding
DATABASE_URL=postgresql+asyncpg://osu:osu@db:5432/modding

# osu! OAuth
OSU_CLIENT_ID=your_osu_client_id_here
OSU_CLIENT_SECRET=your_osu_client_secret_here

# Security
# CHANGE_ME: run `python -c "import secrets; print(secrets.token_urlsafe(32))"` to generate
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_urlsafe_32

# URLs (for local development)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
